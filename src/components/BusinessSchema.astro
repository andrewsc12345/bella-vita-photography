---
interface Props {
  pageType?: 'home' | 'location';
  cityName?: string;
  cityRegion?: string;
  pageUrl?: string;
}

const {
  pageType = 'home',
  cityName,
  cityRegion = 'MI',
  pageUrl = 'https://bellavitabyrebecca.com',
} = Astro.props;

const baseUrl = 'https://bellavitabyrebecca.com';

const schema: Record<string, any> = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  '@id': `${baseUrl}/#business`,
  name: 'Bella Vita Photography',
  alternateName: 'Bella Vita by Rebecca',
  url: baseUrl,
  image: `${baseUrl}/images/bella-vita-og.jpg`,
  logo: `${baseUrl}/images/bella-vita-logo.png`,
  email: 'bellavitabyrebecca@gmail.com',
  telephone: '+1-219-239-6312',
  priceRange: '$$',
  foundingDate: '2009',
  description:
    'Natural light portrait photography serving Livingston and Oakland County, Michigan. ' +
    'Specializing in high school senior portraits, family sessions, and weddings since 2009.',
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Howell',
    addressRegion: 'MI',
    postalCode: '48843',
    addressCountry: 'US',
  },
  areaServed: [
    'Howell, MI',
    'Brighton, MI',
    'Hartland, MI',
    'Fenton, MI',
    'Pinckney, MI',
    'Fowlerville, MI',
    'Milford, MI',
    'South Lyon, MI',
    'Livingston County, MI',
    'Oakland County, MI',
  ].map((name) => ({ '@type': 'Place', name })),
  sameAs: [
    'https://www.instagram.com/bellavitabyrebecca',
    'https://www.facebook.com/bellavitabyrebecca',
  ],
  openingHoursSpecification: {
    '@type': 'OpeningHoursSpecification',
    dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday'],
    opens: '09:00',
    closes: '18:00',
  },
  makesOffer: [
    { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Senior Portrait Mini Session' }, price: '350', priceCurrency: 'USD' },
    { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Senior Portrait Full Session' }, price: '600', priceCurrency: 'USD' },
    { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Family Mini Session' }, price: '175', priceCurrency: 'USD' },
    { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Family Full Session' }, price: '300', priceCurrency: 'USD' },
    { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Wedding Photography' }, priceSpecification: { '@type': 'PriceSpecification', minPrice: '1200', maxPrice: '3500', priceCurrency: 'USD' } },
  ],
};

if (pageType === 'location' && cityName) {
  schema.areaServed = [{ '@type': 'Place', name: `${cityName}, ${cityRegion}` }];
  schema['@id'] = `${pageUrl}/#business`;
  schema.url = pageUrl;
  schema.description =
    `Natural light portrait photographer serving ${cityName}, ${cityRegion} and the ` +
    `surrounding Livingston and Oakland County area. Senior portraits, family sessions, ` +
    `and weddings since 2009.`;
}
---

<script type="application/ld+json" set:html={JSON.stringify(schema)} />
