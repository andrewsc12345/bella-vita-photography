  <!-- Hide SEO content once React has mounted -->
  <script is:inline>
    // Check periodically if React has rendered content
    (function() {
      var check = setInterval(function() {
        var app = document.getElementById('react-app');
        if (app && app.querySelector('[class]')) {
          document.body.classList.add('app-loaded');
          clearInterval(check);
        }
      }, 100);
      // Failsafe: hide after 5 seconds regardless
      setTimeout(function() {
        document.body.classList.add('app-loaded');
        clearInterval(check);
      }, 5000);
    })();
